# Copy this to .env and fill in values. Never commit .env.

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/boardflow
POSTGRES_DB=boardflow

# LLM Configuration
# Provider: 'anthropic' (native API) or 'bedrock' (AWS Bedrock)
LLM_PROVIDER=anthropic

# Anthropic Native API settings (when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=your-api-key-here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# AWS Bedrock settings (when LLM_PROVIDER=bedrock)
# Requires AWS credentials configured (via ~/.aws/credentials or IAM role)
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# BGG API settings
BGG_BASE_URL=https://boardgamegeek.com/xmlapi2
BGG_REQUEST_DELAY_SECONDS=2  # Delay between requests per worker (default: 2s)
BGG_NUM_WORKERS=5  # Number of concurrent workers (default: 5)
BGG_INGEST_LIMIT=1000
BGG_STATS_MAX_AGE_DAYS=7  # Only refresh stats older than this (default: 7 days)

# BGG CSV seed file configuration
# Priority: BGG_CSV_LOCAL_PATH (if set) takes precedence over BGG_CSV_DUMP_URL
# If local path is set, remote URL is ignored (fail-fast if file doesn't exist)
BGG_CSV_DUMP_URL=https://boardgamegeek.com/data_dumps/bg_ranks
BGG_CSV_LOCAL_PATH=./data/boardgames_ranks.csv  # Relative path to CSV file
BGG_CSV_MAX_AGE_HOURS=24  # Warn if local CSV is older than this (default: 24)

# BGG API authentication (required for API requests)
BGG_API_TOKEN=your-token-here  # Bearer token for BGG XML API2 endpoint

# IDF Weighting for Mechanics/Categories
# Controls IDF (Inverse Document Frequency) weighting in recommendations
# IDF boosts rare mechanics/categories and downweights common ones
IDF_ENABLED=true
IDF_SMOOTHING=1.0  # Smoothing factor for IDF: log((N+s)/(df+s))